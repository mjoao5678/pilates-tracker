<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Niche Instructor Training Tracker</title>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --purple: #7F77DD;
    --teal: #1D9E75;
    --coral: #D85A30;
    --bg: #ffffff;
    --bg2: #f5f4f1;
    --text: #1a1a1a;
    --text2: #6b6b6b;
    --border: rgba(0,0,0,0.12);
    --radius: 8px;
    --radius-lg: 12px;
  }
  @media (prefers-color-scheme: dark) {
    :root {
      --bg: #1a1a1a; --bg2: #242424; --text: #f0f0f0;
      --text2: #999; --border: rgba(255,255,255,0.12);
    }
  }
  body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; background: var(--bg); color: var(--text); font-size: 16px; line-height: 1.5; padding: 1rem; }
  .wrap { max-width: 680px; margin: 0 auto; }
  h1 { font-size: 22px; font-weight: 500; margin-bottom: 2px; }
  .sub { font-size: 13px; color: var(--text2); margin-bottom: 1.5rem; }
  .tabs { display: flex; gap: 0; border-bottom: 0.5px solid var(--border); margin-bottom: 1.5rem; }
  .tab { background: none; border: none; border-bottom: 2px solid transparent; padding: 8px 18px; font-size: 14px; cursor: pointer; color: var(--text2); font-family: inherit; margin-bottom: -1px; }
  .tab.active { color: var(--text); border-bottom-color: var(--text); font-weight: 500; }
  .panel { display: none; } .panel.active { display: block; }

  /* metric cards */
  .cards { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 1.75rem; }
  .card { background: var(--bg2); border-radius: var(--radius); padding: 12px 14px; }
  .card-label { font-size: 13px; color: var(--text2); margin-bottom: 4px; }
  .card-val { font-size: 24px; font-weight: 500; margin-bottom: 6px; }
  .bar-wrap { background: var(--border); border-radius: 4px; height: 8px; overflow: hidden; }
  .bar { height: 100%; border-radius: 4px; transition: width 0.3s; }

  /* hour rows */
  .section-title { font-size: 16px; font-weight: 500; border-bottom: 0.5px solid var(--border); padding-bottom: 8px; margin-bottom: 14px; margin-top: 0; }
  .section { margin-bottom: 1.75rem; }
  .hour-row { margin-bottom: 18px; }
  .hour-meta { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 4px; }
  .hour-label { font-size: 14px; font-weight: 500; }
  .hour-count { font-size: 13px; color: var(--text2); }
  .log-row { display: flex; gap: 8px; margin-top: 8px; }
  .log-row input { width: 72px; font-size: 13px; padding: 4px 8px; border-radius: var(--radius); border: 0.5px solid var(--border); background: var(--bg); color: var(--text); }
  .log-row button { font-size: 13px; padding: 4px 14px; border-radius: var(--radius); border: 0.5px solid var(--border); background: var(--bg); color: var(--text); cursor: pointer; }
  .hint { font-size: 12px; color: var(--text2); margin-top: -6px; }

  /* weekly tasks */
  .phase-label { font-size: 12px; font-weight: 500; color: var(--text2); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 10px; }
  .week-block { border: 0.5px solid var(--border); border-radius: var(--radius); margin-bottom: 6px; overflow: hidden; }
  .week-block.current { border-color: var(--purple); border-width: 1.5px; }
  .week-head { width: 100%; display: flex; justify-content: space-between; align-items: center; padding: 10px 14px; background: none; border: none; cursor: pointer; font-family: inherit; font-size: 14px; color: var(--text); text-align: left; }
  .week-block.current .week-head { background: var(--bg2); }
  .badge { font-size: 11px; background: var(--purple); color: #fff; padding: 2px 7px; border-radius: 99px; margin-left: 8px; }
  .week-count { font-size: 12px; color: var(--text2); }
  .week-body { border-top: 0.5px solid var(--border); padding: 0 14px 10px; display: none; }
  .week-body.open { display: block; }
  .cycle-hint { font-size: 11px; color: var(--text2); padding: 6px 0 2px; }
  .task-row { display: flex; align-items: flex-start; gap: 10px; padding: 7px 0; cursor: pointer; border-bottom: 0.5px solid var(--border); }
  .task-row:last-child { border-bottom: none; }
  .task-icon { width: 16px; height: 16px; border-radius: 4px; flex-shrink: 0; margin-top: 2px; display: flex; align-items: center; justify-content: center; border: 1.5px solid var(--border); }
  .task-icon.partial { border-color: var(--purple); background: rgba(127,119,221,0.13); }
  .task-icon.done { background: var(--purple); border-color: var(--purple); }
  .task-icon .dash { width: 8px; height: 2px; background: var(--purple); border-radius: 1px; }
  .task-icon svg { display: block; }
  .task-text { font-size: 14px; }
  .task-text.partial { font-style: italic; }
  .task-text.done { color: var(--text2); text-decoration: line-through; }

  /* calendar */
  .cal-nav { display: flex; justify-content: space-between; align-items: center; margin-bottom: 14px; }
  .cal-nav button { background: none; border: none; font-size: 20px; cursor: pointer; color: var(--text); padding: 0 8px; }
  .cal-month { font-size: 16px; font-weight: 500; }
  .cal-grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 2px; }
  .cal-day-name { font-size: 11px; color: var(--text2); text-align: center; padding: 4px 0; }
  .cal-cell { min-height: 52px; border-radius: var(--radius); border: 0.5px solid transparent; padding: 4px; }
  .cal-cell.has-border { border-color: var(--border); }
  .cal-cell.today { border-color: var(--purple); border-width: 1.5px; }
  .cal-num { font-size: 12px; text-align: right; }
  .cal-cell.today .cal-num { color: var(--purple); font-weight: 500; }
  .cal-event { font-size: 10px; line-height: 1.3; margin-top: 2px; padding: 2px 4px; border-radius: 3px; font-weight: 500; }
  .legend { margin-top: 18px; padding-top: 14px; border-top: 0.5px solid var(--border); }
  .legend-title { font-size: 13px; font-weight: 500; color: var(--text2); margin-bottom: 10px; }
  .legend-row { display: flex; align-items: center; gap: 10px; margin-bottom: 8px; font-size: 13px; }
  .legend-dot { width: 10px; height: 10px; border-radius: 2px; flex-shrink: 0; }
</style>
</head>
<body>
<div class="wrap">
  <div class="sub" id="week-label"></div>
  <h1>Training tracker</h1>
  <div class="sub" id="started-label"></div>

  <div class="tabs">
    <button class="tab active" onclick="switchTab(0)">Hours</button>
    <button class="tab" onclick="switchTab(1)">Weekly tasks</button>
    <button class="tab" onclick="switchTab(2)">Calendar</button>
  </div>

  <!-- HOURS -->
  <div class="panel active" id="panel-0">
    <div class="cards">
      <div class="card">
        <div class="card-label">Mat total</div>
        <div class="card-val" id="mat-total">0 hrs</div>
        <div class="bar-wrap"><div class="bar" id="mat-bar" style="background:var(--purple);width:0%"></div></div>
      </div>
      <div class="card">
        <div class="card-label">Reformer total</div>
        <div class="card-val" id="ref-total">0 hrs</div>
        <div class="bar-wrap"><div class="bar" id="ref-bar" style="background:var(--coral);width:0%"></div></div>
      </div>
    </div>

    <div class="section">
      <div class="section-title">Mat certification</div>
      <div id="mat-rows"></div>
    </div>
    <div class="section">
      <div class="section-title">Reformer certification</div>
      <div id="ref-rows"></div>
      <p class="hint">Observation unlocks after May 2 in-person training.</p>
    </div>
  </div>

  <!-- WEEKLY TASKS -->
  <div class="panel" id="panel-1">
    <div id="tasks-container"></div>
  </div>

  <!-- CALENDAR -->
  <div class="panel" id="panel-2">
    <div class="cal-nav">
      <button onclick="changeMonth(-1)">&#8249;</button>
      <div class="cal-month" id="cal-title"></div>
      <button onclick="changeMonth(1)">&#8250;</button>
    </div>
    <div class="cal-grid" id="cal-day-names"></div>
    <div class="cal-grid" id="cal-cells"></div>
    <div class="legend">
      <div class="legend-title">Key milestones</div>
      <div id="legend-items"></div>
    </div>
  </div>
</div>

<script>
const START = new Date(2026, 2, 28);
const TODAY = new Date();

const MAT = [
  { key: "mat_obs",      label: "Observation",       target: 10,  color: "var(--purple)" },
  { key: "mat_practice", label: "Personal practice",  target: 20,  color: "var(--purple)" },
  { key: "mat_teaching", label: "Practice teaching",  target: 45,  color: "var(--purple)" },
];
const REF = [
  { key: "ref_obs",      label: "Observation",       target: 18,  color: "var(--coral)" },
  { key: "ref_practice", label: "Personal practice",  target: 50,  color: "var(--coral)" },
  { key: "ref_teaching", label: "Practice teaching",  target: 90,  color: "var(--coral)" },
];

const HOUR_DEFAULTS = {
  mat_obs: 0, mat_practice: 4, mat_teaching: 0,
  ref_obs: 0, ref_practice: 8, ref_teaching: 0,
};
const HOURS = JSON.parse(localStorage.getItem('pilates_hours') || JSON.stringify(HOUR_DEFAULTS));
const taskStatesRaw = JSON.parse(localStorage.getItem('pilates_tasks') || '{}');

const KEY_DATES = [
  { date: new Date(2026,3,11), label: "Reformer training day 1", color: "#7F77DD" },
  { date: new Date(2026,3,18), label: "Reformer training day 2", color: "#7F77DD" },
  { date: new Date(2026,4,2),  label: "Reformer last day",       color: "#7F77DD" },
  { date: new Date(2026,9,1),  label: "Mat test-out target",     color: "#1D9E75" },
  { date: new Date(2027,1,1),  label: "Reformer test-out target",color: "#D85A30" },
];

const PHASES = [
  { phase:1, weeks:[1,6],   label:"Mat foundation + Reformer prep",
    tasks:["Log observation hours (1 video or 1 class/wk)","Personal practice 2x/week (home or studio)","Cue out loud 5 min/day","Complete online Mat module (Wed evenings)","First practice teach session with BF"] },
  { phase:2, weeks:[7,22],  label:"Mat volume + Reformer launches",
    tasks:["Mat practice teaching 2-3x/week","Reformer in-person training (Apr 11, 18, May 2)","Begin Reformer observation after May 2","Accumulate Reformer personal practice classes","Switch to Reformer online modules (Wed evenings)"] },
  { phase:3, weeks:[23,35], label:"Mat exam prep + Reformer volume",
    tasks:["Mat written exam prep (Mon/Wed)","Mat demo class prep + run-throughs","Reformer practice teaching 2x/week","Reformer observation hours","Reformer online modules complete by Dec"] },
  { phase:4, weeks:[36,52], label:"Reformer exam prep + test-out",
    tasks:["Reformer written exam review","Reformer demo class practice","Final Reformer teaching hours","Test-out prep"] },
];

// state: 0=unchecked, 1=partial, 2=done
const taskStates = taskStatesRaw;

function weekNum(d) { return Math.floor((d - START) / (7*86400000)) + 1; }
function weekStart(n) { const d = new Date(START); d.setDate(d.getDate()+(n-1)*7); return d; }
function fmtDate(d) { return d.toLocaleDateString("en-US",{month:"short",day:"numeric"}); }

// header
const curWeek = weekNum(TODAY);
document.getElementById("week-label").textContent = "Niche Instructor Training";
document.getElementById("started-label").textContent = `Week ${curWeek} · Started ${fmtDate(START)}`;

// tabs
function switchTab(i) {
  document.querySelectorAll(".tab").forEach((t,j) => t.classList.toggle("active", i===j));
  document.querySelectorAll(".panel").forEach((p,j) => p.classList.toggle("active", i===j));
}

// hours
function renderHours() {
  const matTotal = MAT.reduce((s,r)=>s+HOURS[r.key],0);
  const refTotal = REF.reduce((s,r)=>s+HOURS[r.key],0);
  document.getElementById("mat-total").textContent = matTotal.toFixed(1)+" hrs";
  document.getElementById("ref-total").textContent = refTotal.toFixed(1)+" hrs";
  document.getElementById("mat-bar").style.width = Math.min(100,Math.round(matTotal/75*100))+"%";
  document.getElementById("ref-bar").style.width = Math.min(100,Math.round(refTotal/158*100))+"%";
}

function buildHourRow(container, rows) {
  rows.forEach(r => {
    const pct = Math.min(100, Math.round(HOURS[r.key]/r.target*100));
    const div = document.createElement("div");
    div.className = "hour-row";
    div.id = "row-"+r.key;
    div.innerHTML = `
      <div class="hour-meta">
        <span class="hour-label">${r.label}</span>
        <span class="hour-count" id="count-${r.key}">${HOURS[r.key]} / ${r.target} hrs (${pct}%)</span>
      </div>
      <div class="bar-wrap"><div class="bar" id="bar-${r.key}" style="background:${r.color};width:${pct}%"></div></div>
      <div class="log-row">
        <input type="number" id="inp-${r.key}" min="0" max="10" step="0.5" placeholder="+ hrs" />
        <button onclick="logHours('${r.key}',${r.target},'${r.color}')">Log</button>
      </div>`;
    container.appendChild(div);
  });
}

function logHours(key, target, color) {
  const inp = document.getElementById("inp-"+key);
  const val = parseFloat(inp.value);
  if (!val || isNaN(val)) return;
  HOURS[key] = Math.max(0, parseFloat((HOURS[key]+val).toFixed(1)));
  localStorage.setItem('pilates_hours', JSON.stringify(HOURS));
  inp.value = "";
  const pct = Math.min(100, Math.round(HOURS[key]/target*100));
  document.getElementById("count-"+key).textContent = `${HOURS[key]} / ${target} hrs (${pct}%)`;
  document.getElementById("bar-"+key).style.width = pct+"%";
  renderHours();
}

buildHourRow(document.getElementById("mat-rows"), MAT);
buildHourRow(document.getElementById("ref-rows"), REF);
renderHours();

// weekly tasks
function buildTasks() {
  const container = document.getElementById("tasks-container");
  PHASES.forEach(phase => {
    const phaseDiv = document.createElement("div");
    phaseDiv.style.marginBottom = "1.75rem";
    const pl = document.createElement("div");
    pl.className = "phase-label";
    pl.textContent = `Phase ${phase.phase} · Weeks ${phase.weeks[0]}–${phase.weeks[1]} · ${phase.label}`;
    phaseDiv.appendChild(pl);

    for (let wk = phase.weeks[0]; wk <= phase.weeks[1]; wk++) {
      const isCurrent = wk === curWeek;
      const block = document.createElement("div");
      block.className = "week-block" + (isCurrent ? " current" : "");

      const head = document.createElement("button");
      head.className = "week-head";
      head.innerHTML = `<span>Week ${wk} · ${fmtDate(weekStart(wk))}${isCurrent ? '<span class="badge">current</span>':''}</span><span class="week-count" id="wc-${wk}-${phase.phase}">0/${phase.tasks.length} done</span>`;
      head.onclick = () => body.classList.toggle("open");

      const body = document.createElement("div");
      body.className = "week-body" + (isCurrent ? " open" : "");
      body.innerHTML = `<div class="cycle-hint">Click to cycle: unchecked → partial → done</div>`;

      phase.tasks.forEach((task, ti) => {
        const row = document.createElement("div");
        row.className = "task-row";
        row.id = `tr-${wk}-${ti}`;
        row.onclick = () => cycleTask(wk, ti, phase.tasks.length, phase.phase);
        updateTaskRow(row, wk, ti, task);
        body.appendChild(row);
      });

      block.appendChild(head);
      block.appendChild(body);
      phaseDiv.appendChild(block);
      updateWeekCount(wk, phase.tasks.length, phase.phase);
    }
    container.appendChild(phaseDiv);
  });
}

function taskIcon(state) {
  if (state === 0) return `<div class="task-icon"></div>`;
  if (state === 1) return `<div class="task-icon partial"><div class="dash"></div></div>`;
  return `<div class="task-icon done"><svg width="10" height="8" viewBox="0 0 10 8"><polyline points="1,4 4,7 9,1" fill="none" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></div>`;
}

function updateTaskRow(row, wk, ti, task) {
  const s = taskStates[`${wk}-${ti}`] || 0;
  const cls = s === 2 ? "done" : s === 1 ? "partial" : "";
  row.innerHTML = `${taskIcon(s)}<span class="task-text ${cls}">${task}</span>`;
}

function cycleTask(wk, ti, total, phase) {
  const k = `${wk}-${ti}`;
  taskStates[k] = ((taskStates[k]||0)+1) % 3;
  localStorage.setItem('pilates_tasks', JSON.stringify(taskStates));
  const phase_obj = PHASES.find(p=>p.phase===phase);
  const row = document.getElementById(`tr-${wk}-${ti}`);
  updateTaskRow(row, wk, ti, phase_obj.tasks[ti]);
  updateWeekCount(wk, total, phase);
}

function updateWeekCount(wk, total, phase) {
  const done = Array.from({length:total},(_,i)=>(taskStates[`${wk}-${i}`]||0)===2).filter(Boolean).length;
  const partial = Array.from({length:total},(_,i)=>(taskStates[`${wk}-${i}`]||0)===1).filter(Boolean).length;
  const el = document.getElementById(`wc-${wk}-${phase}`);
  if (el) el.textContent = `${done}/${total} done${partial>0?` · ${partial} partial`:""}`;
}

buildTasks();

// calendar
let calDate = new Date(2026, 2, 1);

function renderCal() {
  const y = calDate.getFullYear(), m = calDate.getMonth();
  document.getElementById("cal-title").textContent = calDate.toLocaleDateString("en-US",{month:"long",year:"numeric"});
  const namesEl = document.getElementById("cal-day-names");
  namesEl.innerHTML = ["Su","Mo","Tu","We","Th","Fr","Sa"].map(d=>`<div class="cal-day-name">${d}</div>`).join("");
  const cells = document.getElementById("cal-cells");
  cells.innerHTML = "";
  const first = new Date(y,m,1).getDay();
  const last = new Date(y,m+1,0).getDate();
  for (let i=0;i<first;i++) { const c=document.createElement("div"); c.className="cal-cell"; cells.appendChild(c); }
  for (let d=1;d<=last;d++) {
    const date = new Date(y,m,d);
    const isToday = date.toDateString()===TODAY.toDateString();
    const ev = KEY_DATES.find(e=>e.date.toDateString()===date.toDateString());
    const c = document.createElement("div");
    c.className = "cal-cell has-border" + (isToday?" today":"");
    c.innerHTML = `<div class="cal-num">${d}</div>${ev?`<div class="cal-event" style="background:${ev.color}22;color:${ev.color}">${ev.label}</div>`:""}`;
    cells.appendChild(c);
  }
  // legend
  document.getElementById("legend-items").innerHTML = KEY_DATES.map(e=>
    `<div class="legend-row"><div class="legend-dot" style="background:${e.color}"></div>${fmtDate(e.date)} — ${e.label}</div>`
  ).join("");
}

function changeMonth(d) { calDate = new Date(calDate.getFullYear(), calDate.getMonth()+d, 1); renderCal(); }
renderCal();
</script>
</body>
</html>
